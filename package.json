{
  "name": "money-trail",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "check": "npm run lint && npm run type-check && npm run format:check && npx expo install --check",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier --check \"**/*.{js,jsx,ts,tsx,json}\"",
    "type-check": "tsc --noEmit",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier --write \"**/*.{js,jsx,ts,tsx,json}\"",
    "format:check": "prettier --check .",
    "test": "jest --watchAll",
    "build:apk:local": "eas build --platform android --profile production --non-interactive --output-dir dist",
    "build:preview": "eas build --profile preview --platform all",
    "build:dev": "eas build --profile development --platform all"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@react-navigation/native": "^7.1.6",
    "expo": "~53.0.22",
    "expo-dev-client": "~5.2.4",
    "expo-font": "~13.3.2",
    "expo-linking": "~7.1.7",
    "expo-router": "~5.1.5",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-system-ui": "~5.0.11",
    "expo-web-browser": "~14.2.0",
    "nativewind": "^4.1.23",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.5",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "^5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-web": "~0.20.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.4",
    "@types/react": "~19.0.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~9.2.0",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^29.2.1",
    "jest-expo": "~53.0.10",
    "prettier": "^3.6.2",
    "react-test-renderer": "19.0.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.8.3"
  },
  "private": true
}
